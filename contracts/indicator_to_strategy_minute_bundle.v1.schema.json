{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "orderflow://contracts/indicator_to_strategy_minute_bundle.v1.schema.json",
  "title": "Orderflow MQ Body Contract V1 (Indicator Engine -> Strategy System Minute Bundle)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "msg_type",
    "message_id",
    "trace_id",
    "routing_key",
    "symbol",
    "ts_bucket",
    "window_code",
    "indicator_count",
    "published_at",
    "producer",
    "indicators"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "msg_type": {
      "type": "string",
      "const": "ind.minute_bundle"
    },
    "message_id": {
      "$ref": "#/$defs/uuid"
    },
    "trace_id": {
      "$ref": "#/$defs/uuid"
    },
    "routing_key": {
      "type": "string",
      "pattern": "^bundle\\.1m\\.[a-z0-9_]+$"
    },
    "symbol": {
      "type": "string",
      "pattern": "^[A-Z0-9]{2,20}$"
    },
    "ts_bucket": {
      "$ref": "#/$defs/timestamp"
    },
    "window_code": {
      "type": "string",
      "const": "1m"
    },
    "indicator_count": {
      "type": "integer",
      "minimum": 0
    },
    "published_at": {
      "$ref": "#/$defs/timestamp"
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "service",
        "instance_id"
      ],
      "properties": {
        "service": {
          "type": "string",
          "const": "indicator_engine"
        },
        "instance_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        }
      }
    },
    "indicators": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[a-z0-9_]+$"
      },
      "additionalProperties": {
        "$ref": "#/$defs/indicator_item"
      }
    }
  },
  "$defs": {
    "uuid": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "indicator_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "window_code",
        "payload"
      ],
      "properties": {
        "window_code": {
          "type": "string",
          "enum": [
            "1m",
            "15m",
            "1h",
            "4h",
            "1d",
            "3d"
          ]
        },
        "payload": {
          "type": "object"
        }
      }
    }
  }
}
